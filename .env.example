ENV="dev"
### Database Vars to format DB_URL: postgresql://username:password@host:port/database 
DB_HOST="localhost"
DB_PORT=5432
DB_NAME="adeeb_db"
DB_USER="postgres"
DB_PASSWORD="postgres"
### Cache
VALKEY_HOST="localhost"
VALKEY_PASSWORD="password"
VALKEY_PORT=6379
### JWT
JWT_PRIVATE="jwt_private_rsa256.key"
JWT_PUBLIC="jwt_public_rsa256.key"